# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=midp_user
POSTGRES_PASSWORD=midp_secret_change_this
POSTGRES_DB=midp_db

# ─── Backend ──────────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=change_this_to_a_long_random_secret_256_bits
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ─── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
